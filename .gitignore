# Google Apps Script artifacts
*.gs.tmp
.gs_temp/

# clasp
.clasp.json
node_modules/
package-lock.json

# Secrets (NEVER commit)
.clasprc.json
.clasprc
*.credentials.json
*-credentials.json
service-account*.json
*-service-account.json

# Environment
.env
.env.local
.env.*.local
config.local.js
settings.local.js

# Test results
test-results/
coverage/
.nyc_output/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
out/

# Local deploy artifacts
apps-script-target/
verify-target/
tmp/
temp/

# OS files
.Trashes
.Spotlight-V100
.fseventsd